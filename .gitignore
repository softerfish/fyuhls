# OS/editor noise
.DS_Store
Thumbs.db
desktop.ini

# Local environment
.env
.env.*
.phpunit.result.cache

# Local docs/instructions not meant for customer installs
/GEMINI.md
/.git
/.github
!/.github/
!/.github/workflows/
!/.github/workflows/generate-sitemap.yml
/.wiki-publish

# Runtime config and secrets
/config/database.php

# Logs and local helper output
/proxy.log
/proxy.js
/storage/logs/*
!/storage/logs/.gitkeep

# Test/dev-only files
/tests/
/instructions/
/main/
!/main/
!/main/*.html
!/main/*.css
!/main/*.xml

# Sessions, uploads, cache, and other runtime storage
/storage/cache/*
!/storage/cache/.gitkeep
/storage/sessions/*
!/storage/sessions/.gitkeep
/storage/uploads/*
!/storage/uploads/.gitkeep
/storage/custom/*
!/storage/custom/.gitkeep
/storage/custom_uploads/*
!/storage/custom_uploads/.gitkeep

# Keep storage hardening rules committed
!/storage/.htaccess
