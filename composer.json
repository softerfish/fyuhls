{
    "name": "fyuhls/filehosting",
    "description": "High-Performance File Hosting Script",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-json": "*",
        "aws/aws-sdk-php": "^3.371"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Plugin\\": "src/Plugin/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "platform": {
            "php": "8.2.0"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    }
}
